# Yadm local gitignore
# These patterns are relative to $HOME

# Sunshine sensitive data
.config/sunshine/credentials/
.config/sunshine/sunshine.log
.config/sunshine/sunshine_state.json

# Opencode node_modules (already ignored by .config/opencode/.gitignore, but double-check)
.config/opencode/node_modules/
.config/opencode/bun.lock
.config/opencode/package-lock.json

# Claude user-specific data
.claude.json
.claude/backups/
.claude/cache/
.claude/debug/
.claude/downloads/
.claude/ide/*.lock

# General exclusions
.cache/
.local/share/
.local/state/

# OS files
.DS_Store
Thumbs.db

# Editor backups
*~
*.swp
*.swo

# Downloaded/compiled things
*.o
*.so
*.dll

# Logs
*.log
