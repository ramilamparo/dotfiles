#!/bin/bash
# Sway Keybindings Cheatsheet - Scratchpad Display

CHEATSHEET="${HOME}/.config/sway/KEYBINDINGS.md"

if [[ ! -f "$CHEATSHEET" ]]; then
    echo "Error: Cheatsheet not found at $CHEATSHEET" >&2
    exit 1
fi

# Ensure go/bin is in PATH
export PATH="$PATH:${HOME}/go/bin"

# Launch ghostty, disable floating, move to scratchpad, and show it
# Use glow's built-in pager (-p flag) instead of piping to less
ghostty --title="Keybindings" -e bash -c "glow -p '${CHEATSHEET}'" &

# Wait for window to appear
sleep 0.5

# Disable floating first (required before moving to scratchpad)
swaymsg '[title="^Keybindings$"] floating disable'

# Move to scratchpad
swaymsg '[title="^Keybindings$"] move to scratchpad'

# Show scratchpad
swaymsg 'scratchpad show'
